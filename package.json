{
  "name": "magic-patterns-vite-template",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx vite",
    "build": "npx vite build",
    "ci:build": "npm run build",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "preview": "npx vite preview",
    "server": "node server/index.js",
    "dev:server": "node --watch server/index.js",
    "start": "concurrently \"npm run server\" \"npm run dev\"",
    "deploy:hooks": "node scripts/triggerDeployHooks.mjs",
    "seed:plans": "node server/scripts/seedWorkoutPlans.js",
    "backfill:workout-catalog": "node server/scripts/backfillWorkoutSetCatalogIds.js",
    "migrate:sql": "node server/scripts/runMigration.js",
    "migrate:pending": "node server/scripts/runPendingMigrations.js"
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "airtable": "^0.12.2",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "framer-motion": "^11.5.4",
    "lucide-react": "0.522.0",
    "mysql2": "^3.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.18",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^5.54.0",
    "@typescript-eslint/parser": "^5.54.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "latest",
    "eslint": "^8.50.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.1",
    "postcss": "latest",
    "tailwindcss": "3.4.17",
    "typescript": "^5.5.4",
    "vite": "^5.2.0"
  }
}

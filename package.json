{
  "name": "magic-patterns-vite-template",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "ci:build": "npm run build",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "preview": "vite preview",
    "server": "node server/index.js",
    "dev:server": "node --watch server/index.js",
    "start": "node scripts/start-dev.mjs",
    "db:ensure-local": "node scripts/ensure-local-db.mjs",
    "icons:sync": "node scripts/sync-mobile-icons.mjs",
    "deploy:vps": "powershell -ExecutionPolicy Bypass -File .\\scripts\\deploy-vps.ps1",
    "deploy:hooks": "node scripts/triggerDeployHooks.mjs",
    "seed:plans": "node server/scripts/seedWorkoutPlans.js",
    "backfill:workout-catalog": "node server/scripts/backfillWorkoutSetCatalogIds.js",
    "migrate:sql": "node server/scripts/runMigration.js",
    "migrate:pending": "node server/scripts/runPendingMigrations.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@emotion/react": "^11.13.3",
    "@fontsource/bebas-neue": "^5.2.7",
    "@fontsource/space-grotesk": "^5.2.10",
    "@ionic/utils-fs": "^3.1.7",
    "@ionic/utils-subprocess": "^3.0.1",
    "@mediapipe/tasks-vision": "^0.10.34",
    "airtable": "^0.12.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "framer-motion": "^11.5.4",
    "lucide-react": "0.522.0",
    "mysql2": "^3.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.18",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^5.54.0",
    "@typescript-eslint/parser": "^5.54.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "latest",
    "eslint": "^8.50.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.1",
    "postcss": "latest",
    "tailwindcss": "3.4.17",
    "typescript": "^5.5.4",
    "vite": "^5.2.0"
  }
